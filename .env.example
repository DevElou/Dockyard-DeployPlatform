# =============================================================================
# Dockyard — variables d'environnement
# Copier ce fichier en .env et remplir les valeurs avant tout déploiement.
# Ne jamais commiter .env dans le dépôt.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données (CockroachDB)
# -----------------------------------------------------------------------------

# DSN Go (pgx) utilisé par l'API et le worker
DOCKYARD_DATABASE_URL=postgresql://root@server-1.local:26257/dockyard?sslmode=disable

# DSN golang-migrate (schéma cockroachdb://) utilisé par make migrate-up
MIGRATE_URL=cockroachdb://root@server-1.local:26257/dockyard?sslmode=disable

# Adresse annoncée par chaque nœud CockroachDB (à surcharger sur chaque host)
COCKROACH_ADVERTISE_ADDR=server-1.local   # server-2.local / server-3.local selon le host

# Liste des nœuds pour le join du cluster
COCKROACH_JOIN=server-1.local:26257,server-2.local:26257,server-3.local:26257

# Répertoire des données CockroachDB sur l'hôte (valeur par défaut si absent)
COCKROACH_DATA_DIR=/opt/dockyard/cockroach

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------

# Token GitHub avec scope `repo` (lecture) sur les projets à builder
# Générer sur https://github.com/settings/tokens
DOCKYARD_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Registry Docker (privé)
# -----------------------------------------------------------------------------

# URL du registry sans schéma (ex: server-1.local:5000)
DOCKYARD_REGISTRY_URL=server-1.local:5000

# Répertoire des images sur l'hôte
REGISTRY_DATA_DIR=/opt/dockyard/registry

# -----------------------------------------------------------------------------
# Deploy Agent
# -----------------------------------------------------------------------------

# Clé partagée entre le worker et tous les agents
# Générer avec : openssl rand -hex 32
DOCKYARD_AGENT_KEY=changeme-generate-with-openssl-rand-hex-32

# Adresse d'écoute de l'agent (défaut :8090)
DOCKYARD_AGENT_ADDR=:8090

# -----------------------------------------------------------------------------
# Control Plane API
# -----------------------------------------------------------------------------

# Adresse d'écoute de l'API (défaut :8080)
DOCKYARD_API_ADDR=:8080

# -----------------------------------------------------------------------------
# Redis (non utilisé en V1, réservé pour les futures jobs queues)
# -----------------------------------------------------------------------------
DOCKYARD_REDIS_ADDR=server-1.local:6379
REDIS_DATA_DIR=/opt/dockyard/redis

# -----------------------------------------------------------------------------
# Nginx Proxy Manager
# -----------------------------------------------------------------------------
NPM_DATA_DIR=/opt/dockyard/nginx-proxy-manager/data
NPM_LETSENCRYPT_DIR=/opt/dockyard/nginx-proxy-manager/letsencrypt

# -----------------------------------------------------------------------------
# Tests d'intégration (développement uniquement)
# -----------------------------------------------------------------------------
DOCKYARD_TEST_DSN=postgresql://root@localhost:26257/dockyard?sslmode=disable
