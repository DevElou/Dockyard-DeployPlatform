# ──────────────────────────────────────────────────────────────────────────────
# .env.dev — Variables pour la stack locale (docker-compose.dev.yml)
# Copier en .env.dev et remplir les valeurs obligatoires.
# ──────────────────────────────────────────────────────────────────────────────

# [OBLIGATOIRE] Token GitHub avec scope `repo` (lecture des dépôts à builder)
# Générer sur https://github.com/settings/tokens
DOCKYARD_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé partagée entre le worker et l'agent
# Générer avec : openssl rand -hex 32
DOCKYARD_AGENT_KEY=dev-agent-key-changeme-generate-with-openssl

# ── NPM (optionnel) ────────────────────────────────────────────────────────────
# Laisser vide pour désactiver le routing (mode noop)
DOCKYARD_NPM_URL=
DOCKYARD_NPM_IDENTITY=admin@example.com
DOCKYARD_NPM_SECRET=changeme
DOCKYARD_NPM_DEFAULT_FORWARD_SCHEME=http

# ── Frontend ────────────────────────────────────────────────────────────────────
# URL de l'API vue depuis le navigateur (hôte, pas réseau Docker interne)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Origines autorisées à appeler l'API depuis le navigateur
DOCKYARD_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
